# Google Maps API key - required for the 3D satellite view on the Map page
# Get your key at https://console.cloud.google.com/google/maps-apis/
# Enable: Maps JavaScript API
VITE_GOOGLE_MAPS_API_KEY=your_api_key_here

# Optional: Google Maps Map ID for photorealistic 3D buildings
# Create a Map ID at https://console.cloud.google.com/google/maps-apis/studio/maps
VITE_GOOGLE_MAPS_MAP_ID=
